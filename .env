COMPOSE_PROJECT_NAME=orion

# --- Postgres OLTP -----------------------------------------------------------
OLTP_DB=orion_oltp
OLTP_USER=orion
OLTP_PASSWORD=orion_pwd
OLTP_PORT=5433

# --- Postgres DWH ------------------------------------------------------------
DWH_DB=orion_dwh
DWH_USER=dwh
DWH_PASSWORD=dwh_pwd
DWH_PORT=5434

# --- SQL Server (moteur ETL) -------------------------------------------------
# Mot de passe SA : doit comporter au moins 8 caractères, dont majuscule,
# minuscule, chiffre et symbole (politique SQL Server par défaut).
MSSQL_SA_PASSWORD=Orion!StrongPwd2026
MSSQL_PORT=1433
MSSQL_PID=Developer

# --- Adminer -----------------------------------------------------------------
# UI web unique pour Postgres OLTP / DWH et SQL Server.
ADMINER_PORT=8080
ADMINER_DESIGN=pepa-linha-dark

# --- Génération de données (volumétrie cible de l'énoncé) --------------------
# 700 employés (range 600-800), 64 fournisseurs, 5500 produits,
# 90 000 clients, 980 000 commandes (~ 2,5M lignes de commande).
# Pour un cycle de TP plus rapide, ramener à GEN_NB_ORDERS=50000 par exemple.
GEN_NB_EMPLOYEES=700
GEN_NB_SUPPLIERS=64
GEN_NB_PRODUCTS=5500
GEN_NB_CUSTOMERS=90000
GEN_NB_ORDERS=980000
GEN_DATE_START=1998-01-01
GEN_DATE_END=2002-12-31
GEN_SEED=42

# --- Planification ETL -------------------------------------------------------
ETL_DAILY_FACT_CRON_HOUR=0
ETL_DAILY_FACT_CRON_MINUTE=0
ETL_RUN_ON_START=true
