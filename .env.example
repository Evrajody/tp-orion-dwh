COMPOSE_PROJECT_NAME=orion

# --- Postgres OLTP -----------------------------------------------------------
OLTP_DB=orion_oltp
OLTP_USER=orion
OLTP_PASSWORD=orion_pwd
OLTP_PORT=5433

# --- Postgres DWH ------------------------------------------------------------
DWH_DB=orion_dwh
DWH_USER=dwh
DWH_PASSWORD=dwh_pwd
DWH_PORT=5434

# --- SQL Server (moteur ETL) -------------------------------------------------
# Mot de passe SA : doit comporter au moins 8 caractères, dont majuscule,
# minuscule, chiffre et symbole (politique SQL Server par défaut).
MSSQL_SA_PASSWORD=Orion!StrongPwd2026
MSSQL_PORT=1433
MSSQL_PID=Developer

# --- pgAdmin -----------------------------------------------------------------
PGADMIN_EMAIL=admin@orion.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080

# --- Génération de données ---------------------------------------------------
GEN_NB_EMPLOYEES=250
GEN_NB_SUPPLIERS=64
GEN_NB_PRODUCTS=600
GEN_NB_CUSTOMERS=5000
GEN_NB_ORDERS=20000
GEN_DATE_START=1998-01-01
GEN_DATE_END=2002-12-31
GEN_SEED=42

# --- Planification ETL -------------------------------------------------------
ETL_DAILY_FACT_CRON_HOUR=0
ETL_DAILY_FACT_CRON_MINUTE=0
ETL_RUN_ON_START=true
