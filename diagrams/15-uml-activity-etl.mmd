%%{init: {"theme":"neutral","flowchart":{"curve":"basis"}}}%%
flowchart TD
    classDef init   fill:#1F4E79,stroke:#1F4E79,color:#FFF
    classDef stop   fill:#000,stroke:#000,color:#FFF
    classDef act    fill:#E8F0E8,stroke:#1F4E79,color:#1F4E79
    classDef sql    fill:#CCE5FF,stroke:#1F4E79,color:#1F2A44,font-weight:bold
    classDef pgsrc  fill:#FFE7CE,stroke:#C8702A,color:#5C3A0F
    classDef pgtgt  fill:#FFFBE5,stroke:#B58900,color:#5C3A0F
    classDef dec    fill:#FFF6D6,stroke:#C8702A,color:#5C3A0F
    classDef err    fill:#FBE5E5,stroke:#B22222,color:#7A1A1A

    S(( )):::init

    subgraph SCH ["⚙ APScheduler (orchestrator)"]
      T1["Trigger cron 00h00<br/>UTC"]:::act
    end

    subgraph EXT ["1️⃣ EXTRACT — Postgres OLTP"]
      direction TB
      E1["Connexion Postgres OLTP<br/>(ops.*)"]:::pgsrc
      E2["Lire watermark<br/>etl.watermark.fait_ventes"]:::pgsrc
      E3["SELECT 7 jeux dénormalisés<br/>(geographie, fournisseur, produit,<br/>client, employe, canal,<br/>lignes_commande &gt; watermark)"]:::pgsrc
    end

    subgraph LOAD ["2️⃣ LOAD STAGING — SQL Server"]
      direction TB
      L1["TRUNCATE staging.*"]:::sql
      L2["INSERT executemany<br/>fast_executemany"]:::sql
    end

    subgraph TR ["3️⃣ TRANSFORM — etl.sp_run_pipeline (T-SQL)"]
      direction TB
      D1["sp_load_dim_date<br/>(idempotent si vide)"]:::sql
      D2["sp_load_dim_canal<br/>sp_load_dim_geographie<br/>sp_load_dim_fournisseur<br/>sp_load_dim_produit<br/><i>SCD1 full reload</i>"]:::sql
      D3{"hash_ligne<br/>changé ?"}:::dec
      D4["fermer version courante<br/>UPDATE est_courant=0"]:::sql
      D5["INSERT version SCD2"]:::sql
      D6["INSERT fait_ventes<br/>+ calcul mesures<br/>+ MERGE watermark"]:::sql
      D7["Skip"]:::sql
    end

    subgraph PUSH ["4️⃣ PUSH — SQL Server → Postgres DWH"]
      direction TB
      X1["TRUNCATE dw.* CASCADE"]:::pgtgt
      X2["SELECT depuis dim.*, fact.*"]:::sql
      X3["COPY → dw.dim_* / dw.fait_ventes"]:::pgtgt
    end

    LOG["etl.run_log<br/>(SQL Server)"]:::sql
    E(( )):::stop

    S --> T1 --> E1 --> E2 --> E3 --> L1 --> L2 --> D1 --> D2 --> D3
    D3 -- non --> D7 --> D6
    D3 -- oui --> D4 --> D5 --> D6
    D6 --> X1 --> X2 --> X3 --> LOG --> E
